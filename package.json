{
  "name": "newsflash-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist",
    "db:create": "wrangler d1 create newsflash-db",
    "db:migrate": "wrangler d1 execute newsflash-db --local --file=./db/schema.sql",
    "db:migrate:prod": "wrangler d1 execute newsflash-db --file=./db/schema.sql",
    "fetch-news": "npx tsx scripts/fetch-news.ts"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "wrangler": "^3.91.0"
  }
}
